{
  "name": "@webui-rubric/cli",
  "version": "0.1.7",
  "private": false,
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "webui-rubric": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@webui-rubric/capture": "workspace:*",
    "@webui-rubric/checks": "workspace:*",
    "@webui-rubric/core": "workspace:*",
    "commander": "^13.0.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/pngjs": "^6.0.5",
    "pngjs": "^7.0.0"
  }
}
