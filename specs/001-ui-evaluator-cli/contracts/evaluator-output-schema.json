{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://webui-rubric.dev/schemas/evaluator-output/v1.1.0",
  "title": "WebUI Rubric Evaluator Output",
  "description": "The evaluation artifact emitted by the webui-rubric CLI per run. Conforms to FR-030.",
  "type": "object",
  "required": [
    "schema_version",
    "rubric_version",
    "run_id",
    "timestamp",
    "target",
    "composite_score",
    "ship_ready",
    "no_progress",
    "blocking",
    "dimensions",
    "top_issues",
    "pixel_comparison",
    "meta"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Semver of this output schema",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "rubric_version": {
      "type": "string",
      "description": "Semver of the rubric definition used",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "run_id": {
      "type": "string",
      "description": "UUID v4 unique to this invocation",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of evaluation start",
      "format": "date-time"
    },
    "target": {
      "type": "object",
      "required": ["url", "content_hash", "captured_at", "settle_timeout_ms"],
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "content_hash": { "type": "string", "description": "SHA-256 hex of captured artifacts" },
        "captured_at": { "type": "string", "format": "date-time" },
        "settle_timeout_ms": { "type": "number", "minimum": 0 }
      }
    },
    "composite_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Weighted average of dimension scores (FR-013)"
    },
    "ship_ready": {
      "type": "boolean",
      "description": "true when blocking is empty and composite >= ship_threshold (FR-035)"
    },
    "no_progress": {
      "type": "boolean",
      "description": "true when delta < 3 across consecutive iterations (FR-035)"
    },
    "blocking": {
      "type": "array",
      "description": "WCAG AA failures requiring resolution (FR-015)",
      "items": {
        "type": "object",
        "required": ["criterion_id", "reason", "wcag_ref", "evidence", "severity"],
        "additionalProperties": false,
        "properties": {
          "criterion_id": { "type": "string" },
          "reason": { "type": "string" },
          "wcag_ref": { "type": "string" },
          "evidence": { "type": "string", "maxLength": 300 },
          "location": { "$ref": "#/$defs/location_reference" },
          "severity": { "type": "integer", "minimum": 0, "maximum": 4 }
        }
      }
    },
    "dimensions": {
      "type": "array",
      "description": "All 10 dimensions with scores and sub-criteria (FR-009)",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "weight",
          "score",
          "sub_criteria",
          "applicable_count",
          "excluded_count"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "weight": { "type": "number", "minimum": 0, "maximum": 100 },
          "score": { "type": "number", "minimum": 0, "maximum": 100 },
          "sub_criteria": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/sub_criterion_finding" }
          },
          "applicable_count": { "type": "integer", "minimum": 0 },
          "excluded_count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "top_issues": {
      "type": "array",
      "description": "Priority-ordered issues, capped at top_issues_cap (FR-016)",
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": [
          "rank",
          "criterion_id",
          "dimension_id",
          "priority_score",
          "score",
          "severity",
          "fix",
          "fix_hash"
        ],
        "additionalProperties": false,
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "criterion_id": { "type": "string" },
          "dimension_id": { "type": "string" },
          "priority_score": { "type": "number", "minimum": 0 },
          "score": { "type": "integer", "minimum": 0, "maximum": 4 },
          "severity": { "type": "integer", "minimum": 0, "maximum": 4 },
          "fix": { "type": "array", "items": { "type": "string" } },
          "fix_hash": { "type": "string" },
          "expected_impact": { "type": ["string", "null"] }
        }
      }
    },
    "pixel_comparison": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["viewports"],
          "additionalProperties": false,
          "properties": {
            "viewports": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "viewport",
                  "diff_pixel_count",
                  "total_pixel_count",
                  "diff_ratio",
                  "threshold",
                  "reference_image_path",
                  "screenshot_dimensions",
                  "reference_dimensions"
                ],
                "additionalProperties": false,
                "properties": {
                  "viewport": { "type": "string" },
                  "diff_pixel_count": { "type": "integer", "minimum": 0 },
                  "total_pixel_count": { "type": "integer", "minimum": 1 },
                  "diff_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
                  "threshold": { "type": "number", "minimum": 0, "maximum": 1 },
                  "diff_png_path": { "type": ["string", "null"] },
                  "reference_image_path": { "type": "string" },
                  "screenshot_dimensions": { "$ref": "#/$defs/dimensions" },
                  "reference_dimensions": { "$ref": "#/$defs/dimensions" },
                  "diff_regions": { "$ref": "#/$defs/diff_regions" }
                }
              }
            }
          }
        }
      ]
    },
    "artifact": {
      "type": "object",
      "description": "Reference to a generated artifact bundle; present only when --artifact-dir was supplied. Paths are relative to dir.",
      "required": ["dir", "manifest_path", "report_path", "viewports"],
      "additionalProperties": false,
      "properties": {
        "dir": { "type": "string" },
        "manifest_path": { "type": "string" },
        "report_path": { "type": "string" },
        "viewports": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["viewport", "reference", "screenshot", "diff", "composite", "regions"],
            "additionalProperties": false,
            "properties": {
              "viewport": { "type": "string" },
              "reference": { "type": "string" },
              "screenshot": { "type": "string" },
              "diff": { "type": ["string", "null"] },
              "composite": { "type": ["string", "null"] },
              "regions": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "required": [
        "cli_version",
        "rubric_version",
        "tool_versions",
        "determinism",
        "redaction",
        "effective_config",
        "duration_ms"
      ],
      "additionalProperties": false,
      "properties": {
        "cli_version": { "type": "string" },
        "rubric_version": { "type": "string" },
        "tool_versions": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["pinned", "resolved"],
            "properties": {
              "pinned": { "type": "string" },
              "resolved": { "type": "string" }
            }
          }
        },
        "determinism": { "type": "string", "enum": ["pinned", "drifted"] },
        "tool_version_drift": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "required": ["pinned", "resolved"],
                "properties": {
                  "pinned": { "type": "string" },
                  "resolved": { "type": "string" }
                }
              }
            }
          ]
        },
        "redaction": { "type": "string", "enum": ["enabled", "disabled"] },
        "effective_config": {
          "type": "object",
          "required": [
            "weights",
            "blocking_toggles",
            "viewports",
            "ship_threshold",
            "iteration_cap",
            "top_issues_cap",
            "tool_fallback_policy",
            "pixelmatch_threshold"
          ],
          "additionalProperties": false,
          "properties": {
            "weights": {
              "type": "object",
              "additionalProperties": { "type": "number" }
            },
            "blocking_toggles": {
              "type": "object",
              "additionalProperties": { "type": "boolean" }
            },
            "viewports": { "type": "object" },
            "ship_threshold": { "type": "number" },
            "iteration_cap": { "type": "integer" },
            "top_issues_cap": { "type": "integer" },
            "tool_fallback_policy": { "type": "string" },
            "pixelmatch_threshold": { "type": "number" }
          }
        },
        "iteration": { "type": ["integer", "null"] },
        "previous_composite": { "type": ["number", "null"] },
        "delta": { "type": ["number", "null"] },
        "attempted_fixes_count": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "number", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "diff_regions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["y_start", "y_end", "diff_pixel_count", "pct_of_total_diff", "elements"],
        "additionalProperties": false,
        "properties": {
          "y_start": { "type": "integer", "minimum": 0 },
          "y_end": { "type": "integer", "minimum": 0 },
          "diff_pixel_count": { "type": "integer", "minimum": 0 },
          "pct_of_total_diff": { "type": "number", "minimum": 0, "maximum": 1 },
          "elements": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["selector", "tagName", "styleDiffs"],
              "additionalProperties": false,
              "properties": {
                "selector": { "type": "string" },
                "tagName": { "type": "string" },
                "styleDiffs": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["property", "actual", "expected"],
                    "additionalProperties": false,
                    "properties": {
                      "property": { "type": "string" },
                      "actual": { "type": "string" },
                      "expected": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "sub_criterion_finding": {
      "type": "object",
      "required": [
        "id",
        "name",
        "score",
        "status",
        "evidence",
        "evidence_source",
        "severity",
        "suggested_fix",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "score": { "type": ["integer", "null"], "minimum": 0, "maximum": 4 },
        "status": { "type": "string", "enum": ["scored", "not_applicable", "tool_unavailable"] },
        "evidence": { "type": "string", "maxLength": 300 },
        "evidence_source": { "type": "string" },
        "severity": { "type": "integer", "minimum": 0, "maximum": 4 },
        "suggested_fix": { "type": "array", "items": { "type": "string" } },
        "location": { "$ref": "#/$defs/location_reference" },
        "confidence": { "type": "string", "enum": ["deterministic", "predicted"] }
      }
    },
    "location_reference": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["selector", "bounding_box", "coordinates"] },
            "selector": { "type": ["string", "null"] },
            "bounding_box": {
              "oneOf": [
                { "type": "null" },
                {
                  "type": "object",
                  "required": ["x", "y", "width", "height"],
                  "properties": {
                    "x": { "type": "number" },
                    "y": { "type": "number" },
                    "width": { "type": "number" },
                    "height": { "type": "number" }
                  }
                }
              ]
            },
            "viewport": { "type": ["string", "null"] }
          }
        }
      ]
    },
    "dimensions": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": false,
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
